FROM python:3.12-slim

LABEL maintainer="Paperclip"
LABEL description="Discord bot that bridges Discord channels to Paperclip agents"

WORKDIR /app

# Install dependencies first for better layer caching.
COPY requirements-discord.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy the bot script.
COPY paperclip-discord-bot.py /app/bot.py

# Run as non-root user.
RUN useradd --create-home --shell /bin/false botuser
USER botuser

CMD ["python", "-u", "bot.py"]
